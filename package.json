{
  "name": "folder-architect",
  "version": "1.0.0",
  "description": "Visualize folder architecture with file-type filtering",
  "author": "You",
  "license": "MIT",
  "main": "frontend/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build:py": "cd backend && pyinstaller --onefile --name folder-architect-backend scan.py",
    "dist": "npm run build:py && electron-builder",
    "dist:linux": "npm run build:py && electron-builder --linux"
  },
  "build": {
    "appId": "com.folderarchitect.app",
    "productName": "Folder Architect",
    "directories": {
      "output": "release"
    },
    "files": [
      "frontend/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/",
        "to": "backend/",
        "filter": ["folder-architect-backend*"]
      }
    ],
    "linux": {
      "target": [
        "deb",
        "AppImage",
        "tar.gz"
      ],
      "category": "Development",
      "icon": "build/icon.png",
      "maintainer": "Folder Architect"
    },
    "deb": {
      "depends": ["libgtk-3-0", "libnotify4", "libnss3", "libxss1", "libxtst6", "xdg-utils", "libatspi2.0-0", "libuuid1", "libsecret-1-0"]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
